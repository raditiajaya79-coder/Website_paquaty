# === Database Configuration ===
# Pilihan 1: Variabel diskrit (Direkomendasikan untuk pengembangan lokal)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database_name
DB_SSL=false

# Pilihan 2: URL koneksi legacy (Railway/Cloud)
# Format: postgresql://user:password@host:port/database
# DATABASE_PUBLIC_URL=your_database_url_here

# === Server Configuration ===
# Port tempat backend akan berjalan (default: 5000)
PORT=5000

# === Security ===
# Secret key untuk menandatangani JWT token
JWT_SECRET=your_jwt_secret_here
